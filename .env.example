# Application
APP_NAME="KES Water API"
APP_VERSION="1.0.0"
APP_DESCRIPTION="Kamra Engineering Solutions - Enterprise Water Engineering Platform"
API_V1_PREFIX="/api/v1"
DEBUG=true

# Server
HOST="127.0.0.1"
PORT=8010

# Security
SECRET_KEY="REPLACE_WITH_A_RANDOM_SECRET_KEY_AT_LEAST_32_CHARACTERS"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DB="kes_water"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="REPLACE_WITH_LOCAL_POSTGRES_PASSWORD"

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]